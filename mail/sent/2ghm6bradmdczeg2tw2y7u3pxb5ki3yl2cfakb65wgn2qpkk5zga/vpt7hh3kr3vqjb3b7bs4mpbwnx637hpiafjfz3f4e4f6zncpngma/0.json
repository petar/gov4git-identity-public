{"value":{"seqno":0,"request":{"ballot_ad_commit":"06de056f1b8fc082303942e8839dd5d2876246a3","ballot_ad":{"community":{"git_repo":"https://github.com/gov4git/testing.project-gov.public.git","git_branch":"main"},"name":["pmp","motion","priority_poll","1"],"title":"Prioritization poll for motion 1","description":"Up/down vote the priority for concern (issue) 1","choices":["rank"],"strategy":"qv","strategy_calc_js":"\nfunction calcVote(tally, voterUser, voteChoice, targetVote) {\n\n     var currentVote = tally.scores_by_user[voterUser][voteChoice].score;\n     var currentCharge = tally.scores_by_user[voterUser][voteChoice].strength;\n     var targetCharge = targetVote * targetVote;\n     var cost = targetCharge - currentCharge;\n\n     return {\n          \"current_vote\": {\n               \"description\": \"Current vote by user on this ballot choice\",\n               \"value\": currentVote,\n          },\n          \"target_vote\" : {\n               \"description\": \"Target vote by user on this ballot choice\",\n               \"value\": targetVote,\n          },\n          \"cost\" : {\n               \"description\": \"Cost of changing the vote\",\n               \"value\": cost,\n          },\n          \"reward\" : {\n               \"description\": \"Possible reward to user under best outcome\",\n               \"value\": 0.0,\n          },\n     }\n}\n","participants_group":"everybody","frozen":false,"closed":false,"cancelled":false,"parent_commit":"3a2000acf2e42aba5a7497c9fde4786dad11dece"},"ballot_elections":[{"vote_id":"lsvmxcfv2iykjqkhousvjyp6cpdzf6d7b6zetskuwjhmp4qsccha","vote_time":"2023-12-14T14:52:09.565155-08:00","vote_choice":"rank","vote_strength_change":10}]}},"plaintext":"","signature":"wz8RfuAl1RkfmCoIKLPtAlIE2cb2D8QZeDI8jkmbfw/ZnN2NSYxPX1Qeg3A1kD7nwFYxU33tFGuv0veC3TV2Aw==","ed25519_public_key":"oo99KckOBQNSLBvVhS/82Iw3W/iWpXTHEh6OS0jVRtE="}
