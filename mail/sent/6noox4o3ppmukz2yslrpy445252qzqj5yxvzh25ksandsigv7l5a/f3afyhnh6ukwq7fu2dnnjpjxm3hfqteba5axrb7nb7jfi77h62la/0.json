{"value":{"seqno":0,"request":{"ballot_ad_commit":"e255cf6aee978595f3ea89ee1321ad1f1374cff5","ballot_ad":{"community":{"git_repo":"https://github.com/gov4git/testing.project-gov.public.git","git_branch":"main"},"name":["pmp","motion","approval_poll","5"],"title":"Approval referendum for motion 5","description":"Up/down vote the approval vote for proposal (pull request) 5","choices":["rank"],"strategy":"qv","strategy_calc_js":"\nfunction calcVote(tally, voterUser, voteChoice, targetVote) {\n\n     var currentVote = tally.scores_by_user[voterUser][voteChoice].score;\n     var currentCharge = tally.scores_by_user[voterUser][voteChoice].strength;\n     var targetCharge = targetVote * targetVote;\n     var cost = targetCharge - currentCharge;\n\n     return {\n          \"current_vote\": {\n               \"description\": \"Current vote by user on this ballot choice\",\n               \"value\": currentVote,\n          },\n          \"target_vote\" : {\n               \"description\": \"Target vote by user on this ballot choice\",\n               \"value\": targetVote,\n          },\n          \"cost\" : {\n               \"description\": \"Cost of changing the vote\",\n               \"value\": cost,\n          },\n          \"reward\" : {\n               \"description\": \"Possible reward to user under best outcome\",\n               \"value\": 0.0,\n          },\n     }\n}\n","participants_group":"everybody","frozen":false,"closed":false,"cancelled":false,"parent_commit":"0c6cfbc3df3a11d0b1e64112c57f34a48c4c9746"},"ballot_elections":[{"vote_id":"5b6vwltz5pvocdhx2lrzvepk7haf6qotw6gcpx2uwjenyc3hjdaq","vote_time":"2023-12-13T14:36:59.320738-08:00","vote_choice":"rank","vote_strength_change":10}]}},"plaintext":"","signature":"K5jVgGL/9ZqCizI7zMw5o/YeDu9Njps5uGqAwLDP3w8VRa+/u0toswL1/qvFUwOne8RGbu5F8GZ5wh81pqgnCQ==","ed25519_public_key":"oo99KckOBQNSLBvVhS/82Iw3W/iWpXTHEh6OS0jVRtE="}
