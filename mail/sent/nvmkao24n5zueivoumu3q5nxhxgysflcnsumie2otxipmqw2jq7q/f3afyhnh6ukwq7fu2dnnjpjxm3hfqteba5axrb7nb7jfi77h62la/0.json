{"value":{"seqno":0,"request":{"ballot_ad_commit":"a72bb1f088a40a85411d3ac4dbe74b5c4f4cf6a0","ballot_ad":{"community":{"git_repo":"https://github.com/gov4git/testing.project-gov.public.git","git_branch":"main"},"name":["pmp","motion","approval_poll","5"],"title":"Approval referendum for motion 5","description":"Up/down vote the approval vote for proposal (pull request) 5","choices":["rank"],"strategy":"qv","strategy_calc_js":"\nfunction calcVote(tally, voterUser, voteChoice, targetVote) {\n\n     var currentVote = tally.scores_by_user[voterUser][voteChoice].score;\n     var currentCharge = tally.scores_by_user[voterUser][voteChoice].strength;\n     var targetCharge = targetVote * targetVote;\n     var cost = targetCharge - currentCharge;\n\n     return {\n          \"current_vote\": {\n               \"description\": \"Current vote by user on this ballot choice\",\n               \"value\": currentVote,\n          },\n          \"target_vote\" : {\n               \"description\": \"Target vote by user on this ballot choice\",\n               \"value\": targetVote,\n          },\n          \"cost\" : {\n               \"description\": \"Cost of changing the vote\",\n               \"value\": cost,\n          },\n          \"reward\" : {\n               \"description\": \"Possible reward to user under best outcome\",\n               \"value\": 0.0,\n          },\n     }\n}\n","participants_group":"everybody","frozen":false,"closed":false,"cancelled":false,"parent_commit":"bbe110298efbb9b751b2ee70e3049141fbb10bd6"},"ballot_elections":[{"vote_id":"lbds5jaasx7h6q2alfemjyyqadkn4vtexvr2i2yu2ir5jc3cnqxq","vote_time":"2023-12-14T14:22:42.926639-08:00","vote_choice":"rank","vote_strength_change":10}]}},"plaintext":"","signature":"WBgy8yiLl1k9ZcT0xe09oICsCX6bTPAiGSbFMzHeGqyVwHYNC/x12PE6OUwNOXqBuz4l72T/IvVSApmBiJyaDg==","ed25519_public_key":"oo99KckOBQNSLBvVhS/82Iw3W/iWpXTHEh6OS0jVRtE="}
